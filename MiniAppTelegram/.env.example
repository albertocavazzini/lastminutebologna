# Copia in .env e compila (non committare .env)

# Base URL web app Google Apps Script (es. https://script.google.com/macros/s/.../exec)
VITE_APPS_SCRIPT_WEBAPP_BASE=

# URL pubblico della mini app (GitHub Pages) — stesso valore del foglio credenziali URL_MINI_APP_TELEGRAM
VITE_PUBLIC_MINI_APP_URL=

# Già usato da MapView se presente
# VITE_GOOGLE_MAPS_API_KEY=
